@model IEnumerable<Genre>

@{
    ViewData["Title"] = "Genres";
}

<div class="genres-header d-flex justify-content-between align-items-center mb-5">
    <h2 class="page-title mb-0">
        <i data-lucide="tags" class="me-2"></i>
        <span>Movie Genres</span>
    </h2>
    
    @if (Model.Any())
    {
        <a class="btn btn-primary btn-modern shadow-lg" asp-action="Create">
            <i data-lucide="plus-circle"></i>
            Add New Genre
        </a>
    }
</div>

<div class="genres-container">
    @if (!Model.Any())
    {
        <div class="empty-state-luxury d-flex align-items-center justify-content-center">
            <div class="empty-card text-center p-5">
                <div class="empty-icon-wrapper mb-4">
                    <div class="empty-icon-bg" style="background: var(--accent);"></div>
                    <i data-lucide="tag" class="empty-icon" style="color: var(--accent);"></i>
                </div>
                <h3 class="fw-bold mb-2">No Genres Yet</h3>
                <p class="text-muted mb-4 px-md-5">Organization is key to a great library. Start by defining the genres that will categorize your cinematic collection.</p>
                <a class="btn btn-primary btn-modern btn-lg px-5 shadow-lg" asp-action="Create">
                    <i data-lucide="plus-circle"></i>
                    Create First Genre
                </a>
            </div>
        </div>
    }
    @if (Model.Any())
    {
        <div class="genres-list-container">
            <div class="row g-4">
                @foreach (var genre in Model)
                {
                    <div class="col-12">
                        <div class="genre-card genre-card-list">
                            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center gap-4">
                                    <div class="genre-icon-small">
                                        <i data-lucide="tag"></i>
                                    </div>
                                    <h5 class="genre-name mb-0">@genre.Name</h5>
                                </div>
                                <div class="action-icons-pill">
                                    <a asp-action="Edit" asp-route-id="@genre.Id" class="icon-btn-modern" title="Edit">
                                        <i data-lucide="pencil"></i>
                                    </a>
                                    <a href="javascript:;" class="icon-btn-modern delete-btn-modern js-delete" data-id="@genre.Id" title="Delete">
                                        <i data-lucide="trash-2"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.js-delete').on('click', function () {
                var btn = $(this);
                var genreId = btn.data('id');
                var genreCard = btn.closest('.genre-card');
                var genreName = genreCard.find('.genre-name').text();

                bootbox.confirm({
                    message: `Are you sure you want to delete the genre "<strong>${genreName}</strong>"?<br><small class="text-muted">This action cannot be undone.</small>`,
                    buttons: {
                        confirm: {
                            label: 'Yes, Delete',
                            className: 'btn-danger'
                        },
                        cancel: {
                            label: 'Cancel',
                            className: 'btn-outline-secondary'
                        }
                    },
                    callback: function (result) {
                        if (result) {
                            $.ajax({
                                url: '/genres/delete/' + genreId,
                                method: 'POST',
                                success: function () {
                                    genreCard.addClass('animate__animated animate__zoomOut');
                                    setTimeout(function () {
                                        genreCard.closest('.col-md-6, .col-lg-4, .col-xl-3').remove();
                                        
                                        // Check if no genres left
                                        if ($('.genre-card').length === 0) {
                                            location.reload();
                                        }
                                    }, 500);
                                    toastr.success('Genre deleted successfully');
                                },
                                error: function (xhr) {
                                    var errorMsg = xhr.responseText || 'Something went wrong!';
                                    toastr.error(errorMsg);
                                }
                            });
                        }
                    }
                });
            });
        });
    </script>
}

