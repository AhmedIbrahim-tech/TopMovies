@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="error-page d-flex align-items-center justify-content-center text-center">
    <div class="error-card p-5 shadow-lg">
        <div class="error-icon mb-4">
            <i data-lucide="alert-triangle" style="width: 80px; height: 80px; color: var(--danger); filter: drop-shadow(0 0 15px rgba(239, 68, 68, 0.4))"></i>
        </div>
        
        <h1 class="display-4 fw-bold mb-2">Oops!</h1>
        
        @if (Model.StatusCode.HasValue)
        {
            <h2 class="h4 text-muted mb-4">Error @Model.StatusCode: Something went wrong.</h2>
        }
        else
        {
            <h2 class="h4 text-muted mb-4">An unexpected error occurred.</h2>
        }

        @if (!string.IsNullOrEmpty(Model.ExceptionMessage))
        {
            <div class="bg-dark bg-opacity-50 p-3 rounded mb-4 border border-danger border-opacity-25 text-start">
                <code class="text-danger small d-block overflow-auto" style="max-height: 100px;">@Model.ExceptionMessage</code>
            </div>
        }

        <p class="mb-5 text-muted px-md-5">
            We encountered an issue while processing your cinematic request. Please try refreshing or return to your collection.
        </p>

        <div class="error-actions d-flex gap-3 justify-content-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-modern px-5">
                <i data-lucide="home"></i>
                Return to Collection
            </a>
            <button onclick="history.back()" class="btn btn-secondary btn-modern px-5">
                <i data-lucide="arrow-left"></i>
                Previous Page
            </button>
        </div>

        @if (Model.ShowRequestId)
        {
            <div class="mt-5 pt-4 border-top border-glass">
                <span class="text-dim small text-uppercase letter-spacing-1">Request Trace ID</span>
                <p class="text-muted small mt-1 font-monospace">@Model.RequestId</p>
            </div>
        }
    </div>
</div>
