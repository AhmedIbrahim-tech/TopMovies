@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Error.</h1>
@if (Model.StatusCode.HasValue)
{
    <h2 class="text-danger">Status Code: @Model.StatusCode</h2>
}
else
{
    <h2 class="text-danger">An error occurred while processing your request.</h2>
}

@if (!string.IsNullOrEmpty(Model.ExceptionMessage))
{
    <p class="text-danger">
        <strong>Error Message:</strong> @Model.ExceptionMessage
    </p>
}

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

@if (Model.StatusCode == 404)
{
    <p>The page you are looking for could not be found.</p>
}
else if (Model.StatusCode == 500)
{
    <p>An internal server error occurred. Please try again later.</p>
}
