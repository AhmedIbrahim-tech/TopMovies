@{
    ViewData["Title"] = "Home";
}

<div class="home-hero text-center">
    <div class="hero-content">
        <div class="hero-icon mb-4">
            <i class="bi bi-camera-reels-fill"></i>
        </div>
        <h1 class="hero-title">Welcome to Top Movies</h1>
        <p class="hero-subtitle">Your ultimate movie collection manager</p>
        <p class="hero-description text-muted mb-5">
            Manage your favorite movies, organize by genres, and keep track of ratings all in one place.
        </p>
        <div class="hero-actions">
            <a asp-controller="Movies" asp-action="Index" class="btn btn-primary btn-modern btn-lg me-3">
                <i class="bi bi-film"></i>
                Browse Movies
            </a>
            <a asp-controller="Genres" asp-action="Index" class="btn btn-secondary btn-modern btn-lg">
                <i class="bi bi-tags"></i>
                Manage Genres
            </a>
        </div>
    </div>

    <div class="features-section mt-5">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-film"></i>
                    </div>
                    <h4>Movie Management</h4>
                    <p class="text-muted">Add, edit, and organize your movie collection with ease.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-tags"></i>
                    </div>
                    <h4>Genre Organization</h4>
                    <p class="text-muted">Categorize movies by genres for better organization.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-star-fill"></i>
                    </div>
                    <h4>Rating System</h4>
                    <p class="text-muted">Rate your favorite movies and keep track of your preferences.</p>
                </div>
            </div>
        </div>
    </div>
</div>

