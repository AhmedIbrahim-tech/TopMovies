@{
    ViewData["Title"] = "Home";
}

<div class="home-hero text-center">
    <div class="hero-content">
        <div class="hero-icon mb-4">
            <i data-lucide="clapperboard"></i>
        </div>
        <h1 class="hero-title display-4 fw-bold">Welcome to TopMovies</h1>
        <p class="hero-subtitle lead text-muted px-md-5">Your ultimate movie collection manager. Experience a premium way to manage your cinematic journey.</p>
        
        <div class="hero-actions mt-5 pt-3">
            <a asp-controller="Movies" asp-action="Index" class="btn btn-primary btn-modern px-5 py-3 me-3">
                <i data-lucide="film" style="width: 20px;"></i>
                Explore Collection
            </a>
            <a asp-controller="Genres" asp-action="Index" class="btn btn-secondary btn-modern px-5 py-3">
                <i data-lucide="layout-grid" style="width: 20px;"></i>
                Manage Genres
            </a>
        </div>
    </div>

    <div class="features-section mt-5 pt-5">
        <div class="row g-4 pt-5">
            <div class="col-md-4">
                <div class="feature-card h-100">
                    <div class="feature-icon-wrapper mb-4">
                        <i data-lucide="camera" class="feature-icon"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Movie Management</h4>
                    <p class="text-muted">Effortlessly add, edit, and organize your vast cinematic collection with a sleek interface.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card h-100">
                    <div class="feature-icon-wrapper mb-4">
                        <i data-lucide="layers" class="feature-icon"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Genre & Tagging</h4>
                    <p class="text-muted">Smart categorization by genres and tags to help you find your next watch in seconds.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card h-100">
                    <div class="feature-icon-wrapper mb-4">
                        <i data-lucide="star" class="feature-icon"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Premium Ratings</h4>
                    <p class="text-muted">Track your favorites with a professional rating system and personalized preferences.</p>
                </div>
            </div>
        </div>
    </div>
</div>

