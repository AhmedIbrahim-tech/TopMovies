@model IEnumerable<Movie>

@{
    ViewData["Title"] = "Movies";
}

<div class="movies-header d-flex justify-content-between align-items-center mb-5">
    <h2 class="page-title mb-0">
        <i data-lucide="film" class="me-2"></i>
        <span>Movies Library</span>
    </h2>
    
    @if (Model.Any())
    {
        <a class="btn btn-primary btn-modern shadow-lg" asp-action="Create">
            <i data-lucide="plus-circle"></i>
            Add New Movie
        </a>
    }
</div>

<div class="movies-container">
    @if (!Model.Any())
    {
        <div class="empty-state-luxury d-flex align-items-center justify-content-center">
            <div class="empty-card text-center p-5">
                <div class="empty-icon-wrapper mb-4">
                    <div class="empty-icon-bg"></div>
                    <i data-lucide="clapperboard" class="empty-icon"></i>
                </div>
                <h3 class="fw-bold mb-2">Your Library is Empty</h3>
                <p class="text-muted mb-4 px-md-5">It's a quiet night in the theater. Start building your cinematic collection by adding your first movie masterpiece.</p>
                <a class="btn btn-primary btn-modern btn-lg px-5 shadow-lg" asp-action="Create">
                    <i data-lucide="plus-circle"></i>
                    Add Your First Movie
                </a>
            </div>
        </div>
    }
    @if (Model.Any())
    {
        <div class="movies-list-container">
            <div class="row g-4">
                @foreach (var movie in Model)
                {
                    <div class="col-12">
                        <div class="movie-card movie-card-list">
                            <div class="row g-0 align-items-stretch">
                                <div class="col-md-3 col-xl-2">
                                    <div class="poster-container-list">
                                        <div class="poster" style="background-image: url(data:image/*;base64,@(Convert.ToBase64String(movie.Poster)))"></div>
                                        <div class="rating-badge-overlay small">
                                            <i data-lucide="star" style="width: 12px; fill: var(--warning); color: var(--warning)"></i>
                                            <span class="ms-1">@movie.Rate.ToString("0.0")</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-9 col-xl-10">
                                    <div class="card-body p-4 d-flex flex-column h-100">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <h5 class="movie-card-title mb-1">@movie.Title</h5>
                                                <span class="movie-card-year">@movie.Year</span>
                                            </div>
                                            <div class="action-icons-pill">
                                                <a asp-action="Details" asp-route-id="@movie.Id" class="icon-btn-modern" title="Details">
                                                    <i data-lucide="eye"></i>
                                                </a>
                                                <a asp-action="Edit" asp-route-id="@movie.Id" class="icon-btn-modern" title="Edit">
                                                    <i data-lucide="pencil"></i>
                                                </a>
                                                <a href="javascript:;" class="icon-btn-modern delete-btn-modern js-delete" data-id="@movie.Id" title="Delete">
                                                    <i data-lucide="trash-2"></i>
                                                </a>
                                            </div>
                                        </div>
                                        
                                        <p class="movie-card-text text-muted mb-0 mt-3">
                                            @(movie.Storeline.Length > 280 ? $"{movie.Storeline.Substring(0, 280)}..." : movie.Storeline)
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.movies-container').on('click', '.js-delete', function () {
                var btn = $(this);

                bootbox.confirm({
                    message: "Are you sure you want to delete this movie?<br><small class=\"text-muted\">This action cannot be undone.</small>",
                    buttons: {
                        confirm: {
                            label: 'Yes, Delete',
                            className: 'btn-danger'
                        },
                        cancel: {
                            label: 'Cancel',
                            className: 'btn-outline-secondary'
                        }
                    },
                    callback: function (result) {
                        if (result) {
                            $.ajax({
                                url: '/movies/delete/' + btn.data('id'),
                                success: function () {
                                    var movieContainer = btn.closest('.movie-card').parent();
                                    movieContainer.find('.movie-card').addClass('animate__animated animate__zoomOut');

                                    setTimeout(function () {
                                        movieContainer.remove();
                                        
                                        // Check if no movies left
                                        if ($('.movie-card').length === 0) {
                                            location.reload();
                                        }
                                    }, 500);

                                    toastr.success('Movie deleted successfully');
                                },
                                error: function () {
                                    toastr.error('Something went wrong!');
                                }
                            });
                        }
                    }
                });
            });
        });
    </script>
}