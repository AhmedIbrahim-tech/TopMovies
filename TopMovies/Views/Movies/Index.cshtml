@model IEnumerable<Movie>

@{
    ViewData["Title"] = "Movies";
}

<div class="movies-header">
    <h2 class="page-title">
        <i class="bi bi-film"></i>
        Movies
    </h2>
    <a class="btn btn-primary btn-modern" asp-action="Create">
        <i class="bi bi-plus-circle"></i>
        Add Movie
    </a>
</div>

<div class="movies-container">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-film"></i>
            </div>
            <h3>No movies found!</h3>
            <p class="text-muted">Get started by adding your first movie.</p>
            <a class="btn btn-primary btn-modern" asp-action="Create">
                <i class="bi bi-plus-circle"></i>
                Add Movie
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var movie in Model)
            {
                <div class="col-12">
                    <div class="movie-card">
                        <div class="row g-0">
                            <div class="col-md-2 poster" style="background-image: url(data:image\/*;base64,@(Convert.ToBase64String(movie.Poster)))"></div>
                            <div class="col-md-10">
                                <div class="card-body">
                                    <div>
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h5 class="movie-card-title">
                                                @movie.Title
                                                <span class="text-muted movie-card-year">(@movie.Year)</span>
                                            </h5>
                                            <div class="rating-badge">
                                                <i class="bi bi-star-fill"></i>
                                                <span>@movie.Rate.ToString("0.0")</span>
                                            </div>
                                        </div>
                                        <p class="card-text text-justify movie-card-text">
                                            @(movie.Storeline.Length > 500 ? $"{movie.Storeline.Substring(0, 500)}..." : movie.Storeline)
                                        </p>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center movie-card-footer">
                                        <div class="movie-actions">
                                            <a asp-action="Details" asp-route-id="@movie.Id" class="btn btn-sm btn-details">
                                                <i class="bi bi-camera-reels"></i>
                                                Details
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@movie.Id" class="btn btn-sm btn-edit">
                                                <i class="bi bi-pencil"></i>
                                                Edit
                                            </a>
                                            <a href="javascript:;" class="btn btn-sm btn-delete js-delete" data-id="@movie.Id">
                                                <i class="bi bi-trash"></i>
                                                Delete
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.js-delete').on('click', function () {
                var btn = $(this);

                bootbox.confirm({
                    message: "Are you sure you want to delete this movie?<br><small class=\"text-muted\">This action cannot be undone.</small>",
                    buttons: {
                        confirm: {
                            label: 'Yes, Delete',
                            className: 'btn-danger'
                        },
                        cancel: {
                            label: 'Cancel',
                            className: 'btn-outline-secondary'
                        }
                    },
                    callback: function (result) {
                        if (result) {
                            $.ajax({
                                url: '/movies/delete/' + btn.data('id'),
                                success: function () {
                                    var movieContainer = btn.closest('.movie-card').parent();
                                    movieContainer.find('.movie-card').addClass('animate__animated animate__zoomOut');

                                    setTimeout(function () {
                                        movieContainer.remove();
                                        
                                        // Check if no movies left
                                        if ($('.movie-card').length === 0) {
                                            location.reload();
                                        }
                                    }, 500);

                                    toastr.success('Movie deleted successfully');
                                },
                                error: function () {
                                    toastr.error('Something went wrong!');
                                }
                            });
                        }
                    }
                });
            });
        });
    </script>
}