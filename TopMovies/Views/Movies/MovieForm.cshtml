@model MovieFormViewModel

@{
    ViewData["Title"] = Model.Id > 0 ? "Edit Movie" : "Create Movie";
}

<div class="form-page-full-width">
    <div class="form-header-modern mb-5 pt-4">
        <h1 class="page-title mb-2">
            <i data-lucide="@(Model.Id > 0 ? "pencil" : "clapperboard")"></i>
            <span>@(Model.Id > 0 ? "Edit Masterpiece" : "Record New Movie")</span>
        </h1>
        <p class="text-muted subtitle-modern">@(Model.Id > 0 ? "Update the details to keep your archive accurate." : "Expand your collection with a new cinematic entry.")</p>
    </div>

    <form method="POST" asp-action="@(Model.Id > 0 ? "Edit" : "Create")" enctype="multipart/form-data" class="needs-validation">
        <input type="hidden" asp-for="Id" />
        
        <div class="row g-5">
            <!-- Form Card Section -->
            <div class="col-xl-8">
                <div class="glass-form-card h-100 mb-0">
                    <div class="row g-4">
                        <div class="col-md-12">
                            <div class="form-group-modern">
                                <label class="form-label-modern" asp-for="Title">Movie Title</label>
                                <input type="text" class="form-control-modern" asp-for="Title" maxlength="250" placeholder="e.g., Inception" required />
                                <span asp-validation-for="Title" class="validation-error"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group-modern">
                                <label class="form-label-modern" asp-for="GenreId">Genre Category</label>
                                <select class="form-control-modern" asp-for="GenreId" asp-items="@(new SelectList(Model.Genres, "Id", "Name"))" required>
                                    <option value="">-- Choose Genre --</option>
                                </select>
                                <span asp-validation-for="GenreId" class="validation-error"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group-modern">
                                <label class="form-label-modern" asp-for="Year">Release Year</label>
                                <input type="number" class="form-control-modern" asp-for="Year" value="@(Model.Year > 0 ? Model.Year : string.Empty)" placeholder="YYYY" required />
                                <span asp-validation-for="Year" class="validation-error"></span>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="form-group-modern">
                                <div class="d-flex justify-content-between">
                                    <label class="form-label-modern" asp-for="Rate">Critic Rating</label>
                                    <span id="rating-val" class="text-primary fw-bold">@(Model.Rate > 0 ? Model.Rate.ToString("0.0") : "5.0")</span>
                                </div>
                                <input type="range" step="0.1" min="0" max="10" class="form-range custom-range" asp-for="Rate" id="RateRange" />
                                <input type="hidden" asp-for="Rate" id="RateInput" />
                                <div class="d-flex justify-content-between small text-dim">
                                    <span>0.0</span>
                                    <span>5.0</span>
                                    <span>10.0</span>
                                </div>
                                <span asp-validation-for="Rate" class="validation-error"></span>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="form-group-modern">
                                <label class="form-label-modern" asp-for="Storeline">Story Plot</label>
                                <textarea class="form-control-modern" asp-for="Storeline" maxlength="2500" rows="8" placeholder="Describe the journey..."></textarea>
                                <span asp-validation-for="Storeline" class="validation-error"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Poster Sidebar Section -->
            <div class="col-xl-4">
                <div class="glass-form-card mb-4 text-center">
                    <label class="form-label-modern mb-3">Live Poster Preview</label>
                    <div id="poster-container" class="@(Model.Id > 0 ? string.Empty : "empty-preview") poster-preview-card-wide shadow-2xl mx-auto">
                        <div class="preview-overlay">
                            <i data-lucide="image" class="preview-placeholder-icon"></i>
                        </div>
                        <img src="@(Model.Id > 0 ? $"data:image/*;base64,{Convert.ToBase64String(Model.Poster)}" : string.Empty)" 
                             alt="Poster Preview" 
                             id="preview-img"
                             class="poster-preview-image @(Model.Id > 0 ? string.Empty : "d-none")" />
                    </div>
                    
                    <div class="mt-4">
                        <div class="custom-file-dropzone-minimal" onclick="document.getElementById('Poster').click()">
                            <i data-lucide="upload-cloud" class="me-2" style="width: 20px;"></i>
                            <span>Upload Poster Portfolio</span>
                            <input type="file" class="d-none" asp-for="Poster" id="Poster" accept=".png, .jpg, .jpeg" />
                        </div>
                        <span asp-validation-for="Poster" class="validation-error"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Master Actions -->
        <div class="form-actions-modern mt-5 pt-4">
            <button type="submit" class="btn btn-primary btn-modern btn-lg px-5 border-0">
                <i data-lucide="check-circle" class="me-2"></i>
                <span>@(Model.Id > 0 ? "Apply Changes" : "Confirm Entry")</span>
            </button>
            <a asp-action="Index" class="btn btn-link text-muted text-decoration-none ms-3">
                <i data-lucide="arrow-left" class="me-1" style="width: 14px;"></i>
                Return to List
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        $(document).ready(function () {
            // Poster Preview Logic
            $('#Poster').on('change', function () {
                var posterCard = $('#poster-container');
                var previewImg = $('#preview-img');
                
                if (this.files && this.files[0]) {
                    var image = window.URL.createObjectURL(this.files[0]);
                    posterCard.removeClass('empty-preview');
                    previewImg.removeClass('d-none').attr('src', image);
                }
            });

            // Rating Range Logic
            var range = $('#RateRange');
            var input = $('#RateInput');
            var valDisp = $('#rating-val');

            range.on('input', function() {
                var v = parseFloat($(this).val()).toFixed(1);
                valDisp.text(v);
                input.val(v);
            });

            // Sync range with input on load
            var initialVal = parseFloat(input.val()) || 5.0;
            range.val(initialVal);
            valDisp.text(initialVal.toFixed(1));

            // Custom Datepicker for Year
            $('#Year').datepicker({
                format: 'yyyy',
                viewMode: 'years',
                minViewMode: 'years',
                autoclose: true,
                startDate: new Date('1950-01-01'),
                endDate: new Date()
            });

            // Form focus polish
            $('.form-control-modern').on('focus', function () {
                $(this).closest('.form-group-modern').addClass('focused');
            }).on('blur', function () {
                $(this).closest('.form-group-modern').removeClass('focused');
            });
        });
    </script>
}